# Telegram (required)
BOT_TOKEN=
ADMIN_ID=

# Channel membership gate
# Channel membership gate — bot must be admin for private channels
# Use @username for public channels, or numeric id (e.g. -1001234567890) for private
REQUIRED_CHANNEL=@HiiTRadio

# VIP admin log channel — numeric ID for private channels (e.g. -1001234567890)
# Leave empty to disable VIP logging. Use /channelid (admin) to discover the ID.
VIP_LOG_CHANNEL_ID=

# SQLite database
DATABASE_PATH=hiit_radio.db

# File cache
CACHE_DIR=cache
CACHE_TTL_HOURS=24

# YouTube / yt-dlp
# Desktop: read live Chrome cookies (optional)
# YTDLP_COOKIES_FROM_BROWSER=chrome
# VPS/headless: copy cookies.txt from PC and set path (browser option does not work on servers)
YTDLP_COOKIES=/home/babak/hiit-radio/cookies.txt
# Optional proxy if YouTube is blocked from VPS (or match your PC proxychains setup)
# YTDLP_PROXY=socks5://127.0.0.1:1080

# Spotify metadata API (Developer Dashboard — does not download audio)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# LLM recommendations for /discover (OpenAI-compatible chat completions)
LLM_API_BASE=https://your-api.example.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Lyrics (optional — LRCLIB works without keys)
GENIUS_API_TOKEN=
MUSIXMATCH_API_KEY=
