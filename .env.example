# Telegram (required)
BOT_TOKEN=
ADMIN_ID=

# Channel membership gate
# Channel membership gate — bot must be admin for private channels
# Use @username for public channels, or numeric id (e.g. -1001234567890) for private
REQUIRED_CHANNEL=@HiiTRadio

# VIP admin log channel — numeric ID for private channels (e.g. -1001234567890)
# Leave empty to disable VIP logging. Use /channelid (admin) to discover the ID.
VIP_LOG_CHANNEL_ID=

# SQLite database
DATABASE_PATH=hiit_radio.db

# File cache
CACHE_DIR=cache
CACHE_TTL_HOURS=24

# YouTube / yt-dlp
YTDLP_COOKIES_FROM_BROWSER=chrome
YTDLP_COOKIES=/path/to/cookies.txt

# Spotify metadata API (Developer Dashboard — does not download audio)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Spotify full download (zotify — requires Premium + credentials.json)
SPOTIFY_CREDENTIALS=/path/to/credentials.json
SPOTIFY_USERNAME=

# Lyrics (optional — LRCLIB works without keys)
GENIUS_API_TOKEN=
MUSIXMATCH_API_KEY=
